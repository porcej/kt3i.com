---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	ogImage?: string;
}

const { title, description, ogImage } = Astro.props;

const site = Astro.site ?? new URL('https://www.kt3i.com');
const canonical = new URL(Astro.url.pathname, site).href;
const ogImageUrl = ogImage
	? new URL(ogImage.startsWith('/') ? ogImage : `/${ogImage}`, site).href
	: new URL('/apple-touch-icon.png', site).href;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<link rel="canonical" href={canonical} />
		<title>{title}</title>
		{description && <meta name="description" content={description} />}
		<meta property="og:title" content={title} />
		{description && <meta property="og:description" content={description} />}
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={ogImageUrl} />
		<meta name="twitter:card" content="summary" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;600&family=Lora:ital,wght@0,400;0,600;1,400&display=swap"
			rel="stylesheet"
		/>
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<link rel="icon" href="/favicon.ico" sizes="any" />
	</head>
	<body>
		<slot />
	</body>
</html>
